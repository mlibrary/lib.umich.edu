---
/**
 * Switch Component - Toggle switch button
 * Converted from src/components/switch.js
 */
interface Props {
  on?: boolean;
  id?: string;
  [key: string]: any;
}

const { on = false, id, ...rest } = Astro.props;
---

<button
  role="switch"
  aria-checked={on ? 'true' : 'false'}
  class="switch-btn"
  id={id}
  {...rest}
>
  <span role="presentation" data-switch-track class="switch-track" data-on={on ? 'true' : 'false'}>
    <span class="switch-label">{on ? 'on' : 'off'}</span>
    <span class="switch-knob"></span>
  </span>
  <slot />
</button>

<style>
  .switch-btn {
    align-items: center;
    display: flex;
    height: 40px;
    outline: none;
    padding: var(--spacing-2xs);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
  }

  .switch-btn:focus .switch-track {
    box-shadow: 0 0 0 3px #ffffff, 0 0 0 4px var(--color-neutral-400);
    outline: none;
  }

  .switch-btn:hover .switch-track {
    box-shadow: 0 0 0 4px var(--color-neutral-100);
  }

  .switch-track {
    background: var(--color-neutral-300);
    border: solid 2px var(--color-neutral-300);
    border-radius: 16px;
    display: inline-block;
    height: 24px;
    margin-right: var(--spacing-xs);
    position: relative;
    width: 58px;
  }

  .switch-track[data-on="true"] {
    background: var(--color-green-500);
    border-color: var(--color-green-500);
  }

  .switch-label {
    color: white;
    display: inline-block;
    font-size: 0.675rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1;
    position: absolute;
    top: 2px;
    right: 5px;
  }

  .switch-track[data-on="true"] .switch-label {
    left: 8px;
    right: auto;
  }

  .switch-knob {
    background: white;
    border-radius: 50%;
    display: inline-block;
    height: 20px;
    position: absolute;
    top: 0px;
    left: 0px;
    width: 20px;
  }

  .switch-track[data-on="true"] .switch-knob {
    left: auto;
    right: 0px;
  }
</style>
