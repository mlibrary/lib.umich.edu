---
/**
 * ChatIframe Component
 * Converted from src/components/chat-iframe.js
 *
 * Embeds the "Ask a Librarian" chat widget via libraryh3lp iframe.
 */
import Heading from '../reusable/Heading.astro';
---

<div class="chat-iframe-container">
  <Heading size="2XS">
    <span class="chat-heading-inner">
      <svg
        height="24"
        viewBox="0 0 24 24"
        width="24"
        class="chat-icon"
      >
        <path
          d="m15.65 15.92v1.88a1.44 1.44 0 0 1 -.43 1 1.37 1.37 0 0 1 -1 .44h-10.3l-2.92 2.96v-13.2a1.39 1.39 0 0 1 .42-1 1.36 1.36 0 0 1 1-.43h5.93v6.9a1.4 1.4 0 0 0 .43 1 1.33 1.33 0 0 0 1 .44z"
          fill="#ffcc06"
        />
        <path
          d="m21.53 4.24a1.45 1.45 0 0 1 1.47 1.45v13.2l-2.95-2.89h-10.28a1.37 1.37 0 0 1 -1-.44 1.47 1.47 0 0 1 -.42-1v-8.87a1.43 1.43 0 0 1 .42-1 1.39 1.39 0 0 1 1-.42z"
          fill="#10284b"
        />
      </svg>
      Ask a Librarian
    </span>
  </Heading>
  <div>
    <iframe
      title="Ask a Librarian"
      width="100%"
      height="400px"
      src="https://libraryh3lp.com/chat/umlibraryaskalibrarian@chat.libraryh3lp.com?skin=36020"
      class="chat-iframe"
    />
  </div>
</div>

<style>
  .chat-iframe-container {
    border: solid 1px var(--color-neutral-100);
    border-radius: 4px;
    border-top: solid 2px var(--color-maize-400);
    margin-top: var(--spacing-s);
    max-width: 20rem;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .chat-heading-inner {
    align-items: center;
    display: flex;
    padding: var(--spacing-2xs) var(--spacing-s);
  }

  .chat-icon {
    flex-shrink: 0;
    height: 32px;
    width: 32px;
    margin-right: var(--spacing-m);
  }

  .chat-iframe {
    border-radius: 4px;
    margin-bottom: -6px;
  }
</style>
