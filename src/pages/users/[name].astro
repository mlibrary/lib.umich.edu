---
/**
 * Staff Profile Pages
 * Generates pages at /users/{uniqname} for every Drupal user.
 * Replaces the Gatsby profile.js template wiring in gatsby-node.js.
 */
import ProfileTemplate from '../../templates/profile.astro';
import Layout from '../../layouts/Layout.astro';
import { getAllUsersForProfiles } from '../../lib/user-data.js';
import { fetchStaff } from '../../lib/staff-data.js';
import { downloadCmsFile } from '../../lib/cms-file-cache.js';

export async function getStaticPaths() {
  const [{ users, included }, staffRawData] = await Promise.all([
    getAllUsersForProfiles(),
    fetchStaff(),
  ]);

  // Build a staff lookup by uniqname for the office field
  const staffByUniqname = new Map();
  for (const raw of (staffRawData || [])) {
    const officeRoom = raw.field_user_room || '';
    const officeBuilding = raw.field_room_building || '';
    const parts = [officeRoom, officeBuilding].filter((p) => p && p.length > 0);
    staffByUniqname.set(raw.name, {
      office: parts.length > 0 ? parts.join(' ') : null,
    });
  }

  // Build included lookup for resolving relationships
  const includedById = {};
  for (const item of (included || [])) {
    includedById[item.id] = item;
  }

  const resolveRelationship = (relData) => {
    if (!relData?.data) return null;
    if (Array.isArray(relData.data)) {
      return relData.data
        .map((ref) => includedById[ref.id])
        .filter(Boolean);
    }
    return includedById[relData.data.id] || null;
  };

  const baseUrl = (process.env.DRUPAL_URL || 'https://cms.lib.umich.edu').replace(/\/$/u, '');

  // Pre-resolve all pronunciation audio file URLs in parallel before the synchronous map.
  const filteredUsers = users.filter((user) => user.attributes?.name);
  const pronunciationUrlMap = new Map();
  await Promise.all(filteredUsers.map(async (user) => {
    const namePronunciation = resolveRelationship(user.relationships?.field_name_pronunciation);
    if (!namePronunciation) return;
    const fileUrl = namePronunciation.attributes?.uri?.url;
    if (!fileUrl) return;
    const absoluteUrl = fileUrl.startsWith('http') ? fileUrl : `${baseUrl}${fileUrl}`;
    const localUrl = await downloadCmsFile(absoluteUrl);
    pronunciationUrlMap.set(user.id, localUrl);
  }));

  return filteredUsers
    .map((user) => {
      const name = user.attributes.name;

      // Resolve media image → file entity
      const mediaImage = resolveRelationship(user.relationships?.field_media_image);
      let profileImage = null;
      if (mediaImage) {
        const fileRef = mediaImage.relationships?.field_media_image?.data;
        const fileEntity = fileRef ? includedById[fileRef.id] : null;
        const fileUrl = fileEntity?.attributes?.uri?.url;
        if (fileUrl) {
          profileImage = {
            url: fileUrl.startsWith('http') ? fileUrl : `${baseUrl}${fileUrl}`,
            alt: fileRef?.meta?.alt || mediaImage.attributes?.field_media_image?.alt || user.attributes.field_user_display_name || '',
          };
        }
      }

      // Resolve departments
      const departments = resolveRelationship(user.relationships?.field_user_department) || [];
      const resolvedDepartments = (Array.isArray(departments) ? departments : [departments])
        .filter(Boolean)
        .map((dept) => ({
          title: dept.attributes?.field_title_context || dept.attributes?.title,
          path: dept.attributes?.path?.alias || null,
        }));

      // Staff data (office)
      const staffData = staffByUniqname.get(name);

      return {
        params: { name },
        props: {
          profile: {
            name: user.attributes.name,
            displayName: user.attributes.field_user_display_name,
            workTitle: user.attributes.field_user_work_title,
            proAbout: user.attributes.field_user_pro_about,
            pronounSubject: user.attributes.field_user_pronoun_subject,
            pronounObject: user.attributes.field_user_pronoun_object,
            pronounDependentPos: user.attributes.field_user_pronoun_dependent_pos,
            pronounIndependentP: user.attributes.field_user_pronoun_independent_p,
            email: user.attributes.field_user_email,
            phone: user.attributes.field_user_phone === '000-000-0000' ? null : user.attributes.field_user_phone,
            orcidId: user.attributes.field_user_orcid_id,
            languagesSpoken: user.attributes.field_languages_spoken,
            physicalAddressPublic: user.attributes.field_physical_address_public_,
            mailingAddress: user.attributes.field_mailing_address,
            makeAnAppointment: user.attributes.field_user_make_an_appointment,
            userUrls: user.attributes.field_user_url,
            socialLinks: {
              linkedin: user.attributes.field_linkedin,
              facebook: user.attributes.field_facebook,
              instagram: user.attributes.field_instagram,
              bluesky: user.attributes.field_bluesky,
              twitter: user.attributes.field_twitter,
            },
            departments: resolvedDepartments,
            image: profileImage,
            pronunciationUrl: pronunciationUrlMap.get(user.id) ?? null,
            office: staffData?.office || null,
          },
        },
      };
    });
}

const { profile } = Astro.props;
---

<ProfileTemplate profile={profile} />
