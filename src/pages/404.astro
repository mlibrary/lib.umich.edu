---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Heading from '../reusable/Heading.astro';
import Link from '../reusable/link.astro';
import Prose from '../components/Prose.astro';
import notFoundImage from '../images/404.png';
---

<Layout title="404 - Page not found">
  <section class="not-found margins">
    <div class="not-found-image-wrap" aria-hidden="true">
      <Image src={notFoundImage} alt="" width={920} class="not-found-image" />
    </div>

    <Heading level={1} size="3XL" class="not-found-heading" data-page-heading>
      <span class="not-found-code">404</span>
      Page not found
    </Heading>

    <Prose class="not-found-prose">
      <p class="lede">
        We can't find the page you're looking for. This can sometimes happen when:
      </p>

      <ul>
        <li>We've moved or renamed the page</li>
        <li>The page no longer exists</li>
        <li>There's a slight typo in the web address</li>
        <li>The web address wasn't copied fully</li>
      </ul>

      <p>
        If the web address is correct, please contact us at
        <Link href="/ask-librarian">Ask a Librarian</Link>
        and we'll do our best to find what you're looking for.
      </p>

      <p>
        You can also visit the <Link href="/">homepage</Link>, navigate through our menu
        options, or use site search.
      </p>
    </Prose>
  </section>
</Layout>

<style>
  .not-found {
    margin-bottom: var(--spacing-5xl);
    margin-top: var(--spacing-xl);
  }

  .not-found-image-wrap {
    margin-bottom: var(--spacing-2xl);
  }

  .not-found-image {
    display: block;
    height: auto;
    max-width: 100%;
    width: 100%;
  }

  .not-found-heading {
    margin-bottom: var(--spacing-m);
    max-width: 42rem;
  }

  .not-found-code {
    color: var(--color-orange-400);
    display: block;
    font-size: 60%;
  }

  .not-found-prose {
    max-width: 42rem;
  }

  @media only screen and (min-width: 769px) {
    .not-found {
      margin-top: var(--spacing-3xl);
    }

    .not-found-image-wrap {
      float: right;
      margin: 0 0 0 var(--spacing-xl);
      max-width: min(40vw, 38rem);
      shape-margin: var(--spacing-xl);
      shape-outside: polygon(
        65px 381px,
        84px 210px,
        -18px 211px,
        -35px 141px,
        -11px 106px,
        103px 115px,
        123px 96px,
        189px 111px,
        262px 27px,
        266px -14px,
        313px -30px,
        427px -29px,
        475px 18px,
        456px 75px,
        458px 177px,
        504px 163px,
        632px 171px,
        632px 225px,
        536px 235px,
        524px 490px,
        44px 491px
      );
      width: 40vw;
    }

    .not-found-prose {
      margin-bottom: var(--spacing-5xl);
    }
  }
</style>
